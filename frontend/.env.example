# ============================================================
# Variables de entorno del frontend
# ============================================================
# 1. Copia este archivo como ".env.local" para desarrollo local.
# 2. En Vercel: ve a Settings > Environment Variables y añade
#    NEXT_PUBLIC_API_URL con la URL de tu Apps Script deployment.
#
# La URL tiene el formato:
# https://script.google.com/macros/s/<DEPLOYMENT_ID>/exec
# ============================================================

NEXT_PUBLIC_API_URL=https://script.google.com/macros/s/REEMPLAZAR_CON_TU_DEPLOYMENT_ID/exec
