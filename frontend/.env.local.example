# URL del Web App de Google Apps Script
NEXT_PUBLIC_API_URL=https://script.google.com/macros/s/TU_DEPLOYMENT_ID/exec

# API key de Google Maps (opcional — sin ella se usa el mapa SVG)
# Obtenla en https://console.cloud.google.com/google/maps-apis
# Habilita "Maps JavaScript API" y restringe la key a tu dominio.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
